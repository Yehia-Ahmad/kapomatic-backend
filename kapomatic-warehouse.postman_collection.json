        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "description": "Set editProduct to true when editing product details without applying newInventory. If both inventoryCount and newInventory are sent, newInventory is added only when editProduct is not true and inventoryCount matches the product's current stored inventoryCount. If they differ, newInventory is ignored.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wireless Mouse Pro\",\n  \"code\": \"WM-001-PRO\",\n  \"editProduct\": true,\n  \"inventoryCount\": {{productInventoryCount}},\n  \"newInventory\": 15,\n  \"categoryId\": \"{{categoryId}}\",\n  \"wholesalePrice\": 9,\n  \"retailPrice\": 17,\n  \"soldItemCount\": 20,\n  \"imageBase64\": \"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAUA\"\n}"
