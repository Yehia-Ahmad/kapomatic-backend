        {
          "name": "Get Customer By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test(\"Customer details include credit summary fields\", function () {",
                  "  pm.expect(data).to.have.property(\"lastCreditSaleDate\");",
                  "  pm.expect(data).to.have.property(\"lastCashSaleDate\");",
                  "  pm.expect(data).to.have.property(\"lastCreditSalePaymentDate\");",
                  "  pm.expect(data).to.have.property(\"creditSummary\");",
                  "  pm.expect(data.creditSummary).to.have.property(\"debtStatusSummary\");",
                  "  pm.expect(data.creditSummary).to.have.property(\"totalDebtAmount\");",
                  "  pm.expect(data.creditSummary).to.have.property(\"paidAmount\");",
                  "  pm.expect(data.creditSummary).to.have.property(\"remainingAmount\");",
                  "  pm.expect(data.creditSummary).to.have.property(\"totalRefundDueAmount\");",
                  "  pm.expect(data.creditSummary).to.have.property(\"totalReturnedPaidAmount\");",
                  "  pm.expect(data.creditSummary).to.have.property(\"totalReallocatedPaidAmount\");",
                  "});",
                  "if (data && data._id) {",
                  "  pm.collectionVariables.set(\"customerId\", data._id);",
                  "}",
                  "if (data && data.name) {",
                  "  pm.collectionVariables.set(\"customerName\", data.name);",
                  "}",
                  "if (data && data.phone) {",
                  "  pm.collectionVariables.set(\"customerPhone\", data.phone);",
                  "}",
                  "if (data && Array.isArray(data.creditHistory) && data.creditHistory[0] && (data.creditHistory[0]._id || data.creditHistory[0].invoiceId)) {",
                  "  pm.collectionVariables.set(\"creditSaleId\", data.creditHistory[0]._id || data.creditHistory[0].invoiceId);",
                  "}"
                ]
              }
            }
