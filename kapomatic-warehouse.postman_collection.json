        {
          "name": "Add Credit Sale Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test(\"Credit-sale payment updates totals\", function () {",
