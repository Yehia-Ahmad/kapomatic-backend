    {
      "name": "Sellings",
      "item": [
        {
          "name": "Get All Selling Invoices",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (Array.isArray(data) && data.length > 0) {",
                  "  pm.test(\"Selling invoices include item productCode\", function () {",
                  "    pm.expect(data[0]).to.have.property(\"items\");",
                  "    if (Array.isArray(data[0].items) && data[0].items.length > 0) {",
                  "      pm.expect(data[0].items[0]).to.have.property(\"productCode\");",
                  "    }",
                  "  });",
                  "  if (data[0]._id) {",
                  "    pm.collectionVariables.set(\"sellingId\", data[0]._id);",
                  "  }",
                  "  if (Array.isArray(data[0].items) && data[0].items[0] && data[0].items[0].productCode) {",
                  "    pm.collectionVariables.set(\"productCode\", data[0].items[0].productCode);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "description": "Returns selling invoices. Each invoice item includes the productCode field.",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sellings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "sellings"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Selling Invoices With Filters",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sellings?categoryId={{categoryId}}&productId={{productId}}&customerName={{customerName}}&customerPhone={{customerPhone}}&sellingDate=2026-02-28",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "sellings"
              ],
              "query": [
                {
                  "key": "categoryId",
                  "value": "{{categoryId}}"
                },
                {
                  "key": "productId",
                  "value": "{{productId}}"
                },
                {
                  "key": "customerName",
                  "value": "{{customerName}}"
                },
                {
                  "key": "customerPhone",
                  "value": "{{customerPhone}}"
                },
                {
                  "key": "sellingDate",
                  "value": "2026-02-28"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Selling Invoice By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test(\"Selling invoice response includes items\", function () {",
                  "  pm.expect(data).to.have.property(\"items\");",
                  "});",
                  "if (data && data._id) {",
                  "  pm.collectionVariables.set(\"sellingId\", data._id);",
                  "}",
                  "if (data && Array.isArray(data.items) && data.items[0] && data.items[0].productCode) {",
                  "  pm.collectionVariables.set(\"productCode\", data.items[0].productCode);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "description": "Returns one selling invoice by invoice document ID.",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sellings/{{sellingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "sellings",
                "{{sellingId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Selling Invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && (data._id || data.invoiceId)) {",
                  "  pm.collectionVariables.set(\"sellingId\", data._id || data.invoiceId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "description": "Creates a selling invoice with one or more items. If no customer exists with the submitted customerName and customerPhone, the backend creates the customer. If the phone already exists with a different name, the customer name is updated.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"{{customerName}}\",\n  \"customerPhone\": \"{{customerPhone}}\",\n  \"sellingDate\": \"2026-03-12\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 2,\n      \"price\": 15\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/sellings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "sellings"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Selling Invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test(\"Updated selling invoice response includes items\", function () {",
                  "  pm.expect(data).to.have.property(\"items\");",
                  "});",
                  "if (data && data._id) {",
                  "  pm.collectionVariables.set(\"sellingId\", data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "description": "Updates a selling invoice. Send the full items array when replacing invoice lines, especially for invoices that contain more than one item.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"{{customerName}}\",\n  \"customerPhone\": \"{{customerPhone}}\",\n  \"sellingDate\": \"2026-03-13\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 3,\n      \"price\": 15\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/sellings/{{sellingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "sellings",
                "{{sellingId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Selling Invoice",
          "request": {
            "method": "DELETE",
            "description": "Deletes a selling invoice and restores its item quantities back to inventory.",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/sellings/{{sellingId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "sellings",
                "{{sellingId}}"
              ]
            }
          },
          "response": []
        }
      ]
    }
