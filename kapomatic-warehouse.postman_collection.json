        {
          "name": "Get Product By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data._id) {",
                  "  pm.collectionVariables.set(\"productId\", data._id);",
                  "}",
                  "if (data && data.inventoryCount !== undefined) {",
                  "  pm.collectionVariables.set(\"productInventoryCount\", String(data.inventoryCount));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
