                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (Array.isArray(data) && data.length > 0) {",
                  "  pm.test(\"Credit-sale invoices include debt and refund totals\", function () {",
                  "    pm.expect(data[0]).to.have.property(\"paidAmount\");",
                  "    pm.expect(data[0]).to.have.property(\"remainingAmount\");",
                  "    pm.expect(data[0]).to.have.property(\"refundDueAmount\");",
                  "    pm.expect(data[0]).to.have.property(\"refundStatus\");",
                  "    pm.expect(data[0]).to.have.property(\"returnedPaidAmount\");",
                  "    pm.expect(data[0]).to.have.property(\"reallocatedPaidAmount\");",
                  "    pm.expect(data[0]).to.have.property(\"payments\");",
                  "    pm.expect(data[0]).to.have.property(\"refunds\");",
                  "  });",
                  "  if (data[0]._id) {",
                  "    pm.collectionVariables.set(\"creditSaleId\", data[0]._id);",
                  "  }",
                  "  if (data[0].status) {",
                  "    pm.collectionVariables.set(\"creditSaleStatus\", data[0].status);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
